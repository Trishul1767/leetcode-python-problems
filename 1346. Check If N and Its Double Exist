class Solution:
    def checkIfExist(self, arr: List[int]) -> bool:
        seen = set()
        
        for num in arr:
            # Check if double is already in the set
            # Or if it's an even number and its half is in the set
            if (num * 2) in seen or (num % 2 == 0 and (num // 2) in seen):
                return True
            
            # Add the current number to the set for future checks
            seen.add(num)
            
        return False
