from collections import Counter

a = "cervelo"

# 1. Counter does your entire first loop automatically
freq = Counter(a) 
print(freq)
# 2. Sort the dictionary items based on the frequency (the value) in descending order
sorted_chars = sorted(freq.items(), key=lambda x: x[1], reverse=True)
print(sorted_chars)
# 3. Rebuild the string using a list comprehension and join
result = "".join([char * count for char, count in sorted_chars])

print(result)
